{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "supabase/contracts/private-invite-participant-request.schema.json",
  "title": "PrivateInviteParticipantRequest",
  "type": "object",
  "additionalProperties": false,
  "required": ["invitation", "process_command_request"],
  "properties": {
    "invitation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "expedition_id",
        "email_normalized",
        "role",
        "token_hash",
        "invited_by_membership_id",
        "expires_at"
      ],
      "properties": {
        "id": {"type": "string", "format": "uuid"},
        "expedition_id": {"type": "string", "format": "uuid"},
        "email_normalized": {
          "type": "string",
          "format": "email",
          "minLength": 3,
          "maxLength": 254
        },
        "role": {"const": "participant"},
        "token_hash": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "invited_by_membership_id": {"type": "string", "format": "uuid"},
        "expires_at": {"type": "string", "format": "date-time"}
      }
    },
    "process_command_request": {
      "allOf": [
        {"$ref": "./private-invitation-process-command-request.schema.json"},
        {
          "properties": {
            "command": {
              "properties": {
                "command_type": {"const": "invite_participant"},
                "actor_role": {"const": "captain"}
              }
            },
            "actor_context": {
              "properties": {
                "actor_role": {"const": "captain"},
                "participant_id": {"type": "null"}
              }
            },
            "events": {
              "minItems": 1,
              "maxItems": 1,
              "prefixItems": [
                {
                  "allOf": [
                    {"$ref": "../../engine/event.schema.json"},
                    {
                      "properties": {
                        "event_type": {"const": "invitation.created"},
                        "actor_role": {"const": "captain"},
                        "day_number": {"type": "null"},
                        "stage_id": {"type": "null"},
                        "day_revision": {"type": "null"}
                      }
                    }
                  ]
                }
              ]
            },
            "projection_mutations": {
              "minItems": 1,
              "maxItems": 1,
              "prefixItems": [
                {
                  "properties": {
                    "operation": {"const": "upsert"},
                    "projection_key": {"const": "expedition_setup_view"},
                    "projection_type": {"const": "expedition_setup_view"},
                    "subject_id": {"type": "null"},
                    "schema_id": {
                      "const": "https://ilka.local/schemas/expedition-setup-view.schema.json"
                    },
                    "schema_version": {"const": "1"},
                    "projection": {
                      "$ref": "../../app/contracts/expedition-setup-view.schema.json"
                    }
                  }
                }
              ]
            }
          }
        }
      ]
    }
  }
}
