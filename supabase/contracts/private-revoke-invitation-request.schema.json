{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "supabase/contracts/private-revoke-invitation-request.schema.json",
  "title": "PrivateRevokeInvitationRequest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "invitation_transition",
    "process_command_request"
  ],
  "properties": {
    "invitation_transition": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "invitation_id",
        "expedition_id",
        "expected_status",
        "revoked_by_profile_id",
        "reason"
      ],
      "properties": {
        "invitation_id": {
          "type": "string",
          "format": "uuid"
        },
        "expedition_id": {
          "type": "string",
          "format": "uuid"
        },
        "expected_status": {
          "const": "pending"
        },
        "revoked_by_profile_id": {
          "type": "string",
          "format": "uuid"
        },
        "reason": {
          "type": "string",
          "minLength": 1,
          "maxLength": 2000,
          "pattern": ".*\\S.*"
        }
      }
    },
    "process_command_request": {
      "allOf": [
        {
          "$ref": "./private-process-command-request.schema.json"
        },
        {
          "properties": {
            "status": {
              "const": "accepted"
            },
            "rejection": {
              "type": "null"
            },
            "command": {
              "properties": {
                "command_type": {
                  "const": "revoke_invitation"
                },
                "actor_role": {
                  "const": "captain"
                },
                "day_number": {
                  "type": "null"
                },
                "stage_id": {
                  "type": "null"
                },
                "day_revision": {
                  "type": "null"
                }
              }
            },
            "actor_context": {
              "properties": {
                "actor_role": {
                  "const": "captain"
                },
                "participant_id": {
                  "type": "null"
                }
              }
            },
            "events": {
              "minItems": 1,
              "maxItems": 1,
              "prefixItems": [
                {
                  "allOf": [
                    {
                      "$ref": "../../engine/event.schema.json"
                    },
                    {
                      "properties": {
                        "event_type": {
                          "const": "invitation.revoked"
                        },
                        "actor_role": {
                          "const": "captain"
                        },
                        "day_number": {
                          "type": "null"
                        },
                        "stage_id": {
                          "type": "null"
                        },
                        "day_revision": {
                          "type": "null"
                        }
                      }
                    }
                  ]
                }
              ]
            },
            "projection_mutations": {
              "minItems": 1,
              "maxItems": 1,
              "prefixItems": [
                {
                  "properties": {
                    "operation": {
                      "const": "upsert"
                    },
                    "projection_key": {
                      "const": "expedition_setup_view"
                    },
                    "projection_type": {
                      "const": "expedition_setup_view"
                    },
                    "subject_id": {
                      "type": "null"
                    },
                    "schema_id": {
                      "const": "https://ilka.local/schemas/expedition-setup-view.schema.json"
                    },
                    "schema_version": {
                      "const": "1"
                    },
                    "projection": {
                      "$ref": "../../app/contracts/expedition-setup-view.schema.json"
                    }
                  }
                }
              ]
            }
          }
        }
      ]
    }
  }
}
